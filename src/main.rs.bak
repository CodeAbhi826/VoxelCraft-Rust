// VoxelCraft main entry point.
//
// NOTE: The full renderer + UI shell (wgpu + egui) is in main.rs.full.
// This stub exists so `cargo test` can run the engine integration tests
// without needing the wgpu/egui version-specific API calls to compile.
//
// To build the full game, rename main.rs.full to main.rs and fix the
// ~20 wgpu/egui API mismatches (documented in REBUILD.md).

fn main() {
    println!("VoxelCraft-Rust engine (library mode)");
    println!("Run `cargo test` to verify the engine works.");
    println!("See REBUILD.md for instructions to build the full graphical game.");
}
